# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# These are used server-side in Edge Functions only (never expose in client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (server-side Edge Function only)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Embeddings (server-side Edge Function only)
OPENAI_API_KEY=sk-...

# App
VITE_APP_URL=http://localhost:5173
